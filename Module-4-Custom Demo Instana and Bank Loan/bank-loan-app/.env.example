# Database Configuration (TIDAK AKAN BEKERJA)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password123
DB_NAME=bank_loan_db
DB_PORT=3306

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration (INSECURE - JANGAN GUNAKAN INI!)
JWT_SECRET=my-super-secret-key-12345
JWT_EXPIRES_IN=24h

# Bcrypt Configuration
BCRYPT_ROUNDS=10

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting (TIDAK DIIMPLEMENTASIKAN)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (TIDAK ADA)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@banknusantara.co.id
SMTP_PASSWORD=emailpassword123

# File Upload (TIDAK DIIMPLEMENTASIKAN)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging (TIDAK ADA)
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Session (TIDAK DIIMPLEMENTASIKAN)
SESSION_SECRET=session-secret-key-12345
SESSION_TIMEOUT=3600000

# Redis (TIDAK ADA)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Admin Credentials (HARDCODED - SECURITY ISSUE!)
ADMIN_EMAIL=admin@banknusantara.co.id
ADMIN_PASSWORD=Admin123!

# Application Settings
APP_NAME=Bank Nusantara
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Jakarta

# Feature Flags (TIDAK DIGUNAKAN)
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_LOAN_AUTO_APPROVAL=false

# Payment Gateway (TIDAK ADA)
PAYMENT_GATEWAY_URL=https://api.payment-gateway.com
PAYMENT_GATEWAY_KEY=pg_key_12345
PAYMENT_GATEWAY_SECRET=pg_secret_12345

# Third Party Services (TIDAK ADA)
CREDIT_SCORE_API_URL=https://api.creditscore.com
CREDIT_SCORE_API_KEY=cs_key_12345

# Monitoring (TIDAK ADA)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# AWS Configuration (TIDAK DIGUNAKAN)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Google OAuth (TIDAK DIIMPLEMENTASIKAN)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Facebook OAuth (TIDAK DIIMPLEMENTASIKAN)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=