apiVersion: v1
kind: Secret
metadata:
  name: bob-secrets
  namespace: production
type: Opaque
stringData:
  # Get your OpenShift token by running: oc whoami -t
  openshift-token: "YOUR_OPENSHIFT_TOKEN_HERE"
  
  # Jenkins credentials (not used - Bob triggers via OpenShift BuildConfig)
  jenkins-user: "not-used"
  jenkins-password: "not-used"
  jenkins-token: "not-used"

---
apiVersion: v1
kind: Secret
metadata:
  name: bob-web-ui-secret
  namespace: production
type: Opaque
stringData:
  # Generate a secret key by running: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
  secret-key: "YOUR_FLASK_SECRET_KEY_HERE"