# ── Watsonx Discovery (Elasticsearch) ─────────────────────────────
ES_HOST=your-elasticsearch-host.databases.appdomain.cloud
ES_PORT=9200
ES_USERNAME=your-es-username
ES_PASSWORD=your-es-password

# Certificate options (choose one):
# Option 1: Path to certificate file (for local development)
# ES_CERT_PATH=/path/to/your/cert.crt

# Option 2: Certificate content as string (for deployment/Watsonx Orchestrate)
# ES_CERT_CONTENT="-----BEGIN CERTIFICATE-----
# <your-certificate-content>
# -----END CERTIFICATE-----"

ES_VERIFY_CERTS=false
ES_USE_SSL=true

# ── IBM Watsonx Orchestrate (ADK) ─────────────────────────────────
WATSONX_ORCHESTRATE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/your-instance-id
WXO_APIKEY=your-wxo-api-key

# ── IBM watsonx.ai ─────────────────────────────────────────────────
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_APIKEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id

# ── ServiceNow ─────────────────────────────────────────────────────
SNOW_INSTANCE_URL=https://your-instance.service-now.com
SNOW_USERNAME=your-servicenow-username
SNOW_PASSWORD=your-servicenow-password

# ── GitHub (Root-Cause Investigation) ──────────────────────────────
# Personal Access Token — needs: repo (read), actions (read)
GITHUB_TOKEN=your-github-pat
# Owner login (user or org) — e.g. gredss
GITHUB_REPO_OWNER=your-github-owner
# Repository name — e.g. root-cause-investigation
GITHUB_REPO_NAME=your-github-repo-name

# ── Root-Cause Investigation Runner ────────────────────────────────
# Default ServiceNow incident sys_id for run_investigation.py / test_local_tools.py
INVESTIGATION_DEFAULT_SYS_ID=your-incident-sys-id
# synthesis_agent UUID from Watsonx Orchestrate (Settings → Agents → synthesis_agent → ID)
SYNTHESIS_AGENT_ID=your-synthesis-agent-uuid

# ── Watson OpenScale Guardrails ─────────────────────────────────────
# Watson OpenScale policy / inventory / governance instance IDs (guardrails/)
WATSON_OPENSCALE_POLICY_ID=your-openscale-policy-id
WATSON_OPENSCALE_INVENTORY_ID=your-openscale-inventory-id
WATSON_OPENSCALE_GOVERNANCE_INSTANCE_ID=your-openscale-governance-instance-id
